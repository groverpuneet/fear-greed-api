# Optional: persist the India Fear & Greed 30-day history in a secret GitHub Gist
# so it survives Render restarts and free-tier sleep cycles.
#
# If these are unset, the service still works — India history is kept in memory
# only (and resets when the instance restarts).
#
# Setup:
#   1. Create a GitHub Personal Access Token with ONLY the "gist" scope:
#        https://github.com/settings/tokens  -> Generate new token
#   2. Create the initial gist (one-off) with the token exported:
#        GITHUB_GIST_TOKEN=<token> python scripts/create_gist.py
#      That prints the gist id — use it below.
#   3. Add both variables to Render:
#        Dashboard -> your service -> Environment -> Add Environment Variable

GITHUB_GIST_TOKEN=your_github_pat_with_gist_scope
GITHUB_GIST_ID=your_gist_id
